{
	"$schema": "https://frontmatter.codes/frontmatter.schema.json",
	"frontMatter.framework.id": "astro",
	"frontMatter.preview.host": "http://localhost:4321",
	"frontMatter.content.publicFolder": "public",
	"frontMatter.content.pageFolders": [
		{
			"title": "posts",
			"path": "[[workspace]]/src/content/posts"
		}
	],
	"frontMatter.taxonomy.contentTypes": [
		{
			"name": "posts",
			"previewPath": "posts",
			"pageBundle": false,
			"clearEmpty": false,
			"fields": [
				{
					"name": "title",
					"type": "string",
					"single": true,
					"required": true
				},
				{
					"name": "published",
					"type": "datetime",
					"default": "{{now}}",
					"isPublishDate": true,
					"required": true
				},
				{
					"name": "draft",
					"type": "draft"
				},
				{
					"name": "description",
					"type": "string",
					"single": true
				},
				{
					"name": "image",
					"type": "image",
					"isPreviewImage": true
				},
				{
					"name": "tags",
					"type": "tags"
				},
				{
					"name": "category",
					"type": "string",
					"single": true
				}
			]
		}
	],
	"frontMatter.framework.startCommand": "pnpm dev",
	"frontMatter.git.enabled": true
}
